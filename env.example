# ─────────────────────────────────────────────────────────────────────────────
# Quorum — Environment Variables
# Sprint 4 (S4-04): all security-critical vars added with generation commands.
# Sprint 5 (S5-05): AI_PROVIDER default changed to 'anthropic'.
#
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# Set all vars marked [REQUIRED in production] in Railway → Variables before
# deploying to production. Missing required vars cause the affected feature to
# fail loudly (not silently).
# ─────────────────────────────────────────────────────────────────────────────


# ── AI Provider ───────────────────────────────────────────────────────────────
# Switch between 'anthropic' and 'deepseek' — no code change needed.
# Default: 'anthropic'.
#
# WARNING: DeepSeek requires explicit opt-in. Setting AI_PROVIDER=deepseek means
# user decision text is processed by servers outside the EU/India. You MUST add a
# DeepSeek cross-border transfer disclosure to your Privacy Policy before enabling.
#
AI_PROVIDER=anthropic

# Anthropic — https://console.anthropic.com/
# [REQUIRED in production when AI_PROVIDER=anthropic]
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# Optional: override model. Defaults to claude-sonnet-4-20250514 in lib/ai-client.ts
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# DeepSeek — https://platform.deepseek.com/
# [REQUIRED in production when AI_PROVIDER=deepseek]
DEEPSEEK_API_KEY=sk-REPLACE_ME

# Optional: override model. Defaults to deepseek-chat in lib/ai-client.ts
# DEEPSEEK_MODEL=deepseek-chat


# ── Supabase ──────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
# [ALL THREE REQUIRED in production]
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE_ME.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJREPLACE_ME
SUPABASE_SERVICE_ROLE_KEY=eyJREPLACE_ME
# ⚠️  SUPABASE_SERVICE_ROLE_KEY is the DB master key — server-side only.
#     NEVER send it in HTTP headers or expose it client-side.
#     Use PAYMENT_WEBHOOK_SECRET for payment route auth (see below).


# ── App ───────────────────────────────────────────────────────────────────────
# [REQUIRED in production — used for internal server-to-server API calls]
NEXT_PUBLIC_APP_URL=https://your-app.railway.app


# ── Encryption ────────────────────────────────────────────────────────────────
# AES-256-GCM field-level encryption key for decision text and analysis stored in DB.
# [REQUIRED in production — without this, decision text is stored in plaintext]
#
# Generate a new key:
#   openssl rand -hex 32
#
# IMPORTANT: back up this key securely. If lost, encrypted rows cannot be decrypted.
# Never rotate without a migration script to re-encrypt existing rows first.
#
DB_ENCRYPTION_KEY=REPLACE_ME_with_openssl_rand_hex_32


# ── Admin & Internal Auth ─────────────────────────────────────────────────────
# ADMIN_CODE: Bearer token for /api/admin/* routes.
# [REQUIRED in production — without this, admin endpoints return 401 and are unusable]
#
# Generate:
#   openssl rand -hex 32
#
ADMIN_CODE=REPLACE_ME_with_openssl_rand_hex_32

# CRON_SECRET: Bearer token for /api/cron/* routes (Railway cron jobs).
# [REQUIRED in production — without this, cron endpoints are disabled]
#
# Generate:
#   openssl rand -hex 32
#
CRON_SECRET=REPLACE_ME_with_openssl_rand_hex_32

# PAYMENT_WEBHOOK_SECRET: x-admin-key header for /api/payment/create-subscription.
# MUST be a separate secret — never the SUPABASE_SERVICE_ROLE_KEY.
# [REQUIRED in production if you use the payment provisioning endpoint]
#
# Generate:
#   openssl rand -hex 32
#
PAYMENT_WEBHOOK_SECRET=REPLACE_ME_with_openssl_rand_hex_32

# INTERNAL_API_SECRET: Bearer token for server-to-server internal routes
# (/api/ontology, /api/bias-score, /api/structural-match).
# Added in Sprint 5 (S5-03) — set now so it's ready when S5 is deployed.
# [REQUIRED in production after Sprint 5 is deployed]
#
# Generate:
#   openssl rand -hex 32
#
INTERNAL_API_SECRET=REPLACE_ME_with_openssl_rand_hex_32


# ── Decision Brief ────────────────────────────────────────────────────────────
# BRIEF_ACCESS_TOKEN: Bearer token to gate PDF brief generation.
# [REQUIRED in production if Decision Brief feature is enabled]
#
# Generate:
#   openssl rand -hex 32
#
BRIEF_ACCESS_TOKEN=REPLACE_ME_with_openssl_rand_hex_32


# ── Mirror Subscription Tokens ────────────────────────────────────────────────
# Manual unlock tokens for Mirror module tiers (used before Razorpay is wired up).
# [REQUIRED in production if manually provisioning Mirror access]
#
# Generate each:
#   openssl rand -hex 32
#
MIRROR_TOKEN_MONTHLY=REPLACE_ME_with_openssl_rand_hex_32
MIRROR_TOKEN_ANNUAL=REPLACE_ME_with_openssl_rand_hex_32
MIRROR_TOKEN_LIFETIME=REPLACE_ME_with_openssl_rand_hex_32


# ── Voice / TTS ───────────────────────────────────────────────────────────────
# Soniox API key for Council Synthesis read-aloud (Sprint 23).
# https://soniox.com
# [REQUIRED in production if TTS feature is enabled]
SONIOX_API_KEY=REPLACE_ME


# ── Optional Tuning (defaults are safe — only override if needed) ─────────────
# Structural retrieval minimum cosine similarity to surface a past decision
# MATCH_THRESHOLD=0.72

# Avoidance detector: minimum sessions before running pattern detection
# MIN_SESSIONS=3
# AVOIDANCE_DAYS_THRESHOLD=45
# RERUN_DAYS_THRESHOLD=90
# PATTERNS_SESSION_THRESHOLD=5
# RULES_SESSION_THRESHOLD=8

# Mirror module routing mode (future use)
# ROUTING_MODE=standard

# Structural echo minimum similarity score
# STRUCTURAL_ECHO_MIN_SCORE=65
